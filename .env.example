# Environment variables (copy to .env and fill in real values)
DATABASE_URL=postgresql://user:password@localhost:5432/orgmcalc

# OrgAuth JWKS validation
AUTH_API_URL=https://auth.or-gm.com

# R2/S3 Object Storage (Phase 1 setup, Phase 7 usage)
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=orgmcalc-uploads
